{
  "manifest_version": 3,
  "name": "Comment Names for Regulations.gov (Unofficial)",
  "version": "1.1.0",
  "description": "Unofficial. Shows the commenting organization or person's name on Regulations.gov comment lists, and filters the list by submitter type or attachment.",
  "permissions": ["storage"],
  "host_permissions": ["https://api.regulations.gov/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.regulations.gov/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "options.html",
    "default_title": "Comment Names for Regulations.gov",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
